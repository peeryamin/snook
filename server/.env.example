PORT=8080
HOST=0.0.0.0
NODE_ENV=production
JWT_SECRET=CHANGE-ME-use-openssl-rand-base64-32
CORS_ORIGIN=http://localhost:8080
CLUB_TIMEZONE=Asia/Kolkata

# SQLite path (Docker uses /data/parlor.db). On Vercel without Turso, data is ephemeral.
DB_PATH=

# Turso (required for reliable Vercel production — https://turso.tech)
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=

# Daily report email (optional)
REPORT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

DAILY_RESET_HOUR=23
DAILY_RESET_MINUTE=59
